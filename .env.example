# PromptFolio Environment Variables
# Copy this file to .env.local and fill in your values

# Groq API Key (get one at https://console.groq.com)
# When set, the app will use the live Groq API (llama-3.3-70b-versatile)
# When missing or empty, the app runs in Mock AI Mode automatically
VITE_GROQ_API_KEY=gsk_your_key_here
